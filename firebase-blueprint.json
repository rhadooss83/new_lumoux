{
  "entities": {
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "A message submitted through the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the sender" },
        "phone": { "type": "string", "description": "Phone number of the sender" },
        "email": { "type": "string", "format": "email", "description": "Email of the sender" },
        "place": { "type": "string", "description": "Location of the sender" },
        "service": { "type": "string", "description": "Requested service" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of submission" }
      },
      "required": ["name", "phone", "email", "place", "service", "message", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "A portfolio project.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project" },
        "title": { "type": "string", "description": "Title of the project" },
        "description": { "type": "string", "description": "Description of the project" },
        "thumbnail": { "type": "string", "description": "URL of the thumbnail image" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "Array of image URLs" },
        "order": { "type": "number", "description": "Order of the project in the portfolio" }
      },
      "required": ["id", "title", "description", "thumbnail", "images"]
    },
    "SiteContent": {
      "title": "SiteContent",
      "description": "Global site content like profile picture and about text.",
      "type": "object",
      "properties": {
        "profilePicture": { "type": "string", "description": "URL of the profile picture" },
        "aboutText": { "type": "string", "description": "About me text" },
        "heroTitle": { "type": "string", "description": "Hero section title" },
        "heroSubtitle": { "type": "string", "description": "Hero section subtitle" },
        "portfolioTitle": { "type": "string", "description": "Portfolio section title" },
        "servicesTitle": { "type": "string", "description": "Services section title" },
        "servicesSubtitle": { "type": "string", "description": "Services section subtitle" },
        "servicesBottomText1": { "type": "string", "description": "Services bottom text paragraph 1" },
        "servicesBottomText2": { "type": "string", "description": "Services bottom text paragraph 2" },
        "servicesList": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "expandedText": { "type": "string" },
              "icon": { "type": "string" }
            }
          }, 
          "description": "List of services" 
        },
        "contactTitle": { "type": "string", "description": "Contact section title" },
        "contactSubtitle1": { "type": "string", "description": "Contact section subtitle 1" },
        "contactSubtitle2": { "type": "string", "description": "Contact section subtitle 2" },
        "contactHomeText1": { "type": "string", "description": "Contact section home text 1" },
        "contactHomeText2": { "type": "string", "description": "Contact section home text 2" }
      }
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ContactMessage" },
      "description": "Collection of contact form messages."
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Collection of portfolio projects."
    },
    "/settings/content": {
      "schema": { "$ref": "#/entities/SiteContent" },
      "description": "Global site content document."
    }
  }
}
