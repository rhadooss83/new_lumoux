rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /messages/{messageId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'email', 'place', 'service', 'createdAt']);
      allow read, update, delete: if request.auth != null && request.auth.token.email == "rhadooss83@gmail.com";
    }
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "rhadooss83@gmail.com";
    }
  }
}
